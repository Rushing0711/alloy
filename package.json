{
  "name": "@alloy/cli",
  "version": "0.1.0",
  "description": "Alloy - OpenSpec + Superpowers 编排层 CLI 工具",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "alloy": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "compat.yaml",
    "skills/",
    "vendor/",
    "openspec/schemas/alloy/"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.0",
    "semver": "^7.7.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
